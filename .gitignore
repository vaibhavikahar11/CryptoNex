# ============================================
# CryptoNex Root .gitignore
# ============================================

# --- Node.js dependencies (all sub-projects) ---
node_modules/
**/node_modules/

# --- Build output ---
dist/
build/
**/dist/
**/build/

# --- Environment variables (NEVER push secrets) ---
.env
.env.local
.env.production
**/.env
**/.env.local
**/.env.production

# --- Java / Maven build output ---
**/target/
**/*.class
**/*.jar
**/*.war

# --- Vite cache ---
**/.vite/
**/node_modules/.vite/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE files ---
.idea/
.vscode/
*.iml

# --- Test scripts (dev only) ---
test-*.js
