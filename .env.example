# CryptoNex Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# API GATEWAY CONFIGURATION
# ============================================
PORT=3000
BACKEND_URL=http://localhost:1106
BOT_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ============================================
# FRONTEND CONFIGURATION (React/Vite)
# ============================================
VITE_API_BASE_URL=http://localhost:3000
VITE_APP_NAME=CryptoNex
VITE_APP_VERSION=0.0.1

# ============================================
# CRYPTO BOT CONFIGURATION (Node.js)
# ============================================
BOT_PORT=5000
NODE_ENV=development
GEMINI_API_KEY=your_gemini_api_key_here
SPRING_BOOT_URL=http://localhost:3000

# ============================================
# BACKEND CONFIGURATION (Spring Boot)
# ============================================
SERVER_PORT=1106
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Database Configuration (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://dpg-cvqevvjipnbc73crbqt0-a.oregon-postgres.render.com:5432/cryptonex_e9gg
SPRING_DATASOURCE_USERNAME=shivam
SPRING_DATASOURCE_PASSWORD=your_password_here
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Email Configuration
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
MAIL_USERNAME=cryptonex.in@gmail.com
MAIL_PASSWORD=your_email_password_here
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ============================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================
STRIPE_API_KEY=your_stripe_api_key_here
RAZORPAY_API_KEY=your_razorpay_api_key_here

# ============================================
# EXTERNAL API KEYS
# ============================================
COINGECKO_API_KEY=your_coingecko_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# DOCKER/DEPLOYMENT CONFIGURATION
# ============================================
COMPOSE_PROJECT_NAME=cryptonex
ENVIRONMENT=development
DEBUG=false
